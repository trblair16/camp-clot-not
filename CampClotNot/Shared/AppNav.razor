        <a href="/admin/schedule-item-types" @onclick="() => _adminSheetOpen = false">🗂️ Types</a>
        <div class="nav-admin-sheet-section">People</div>
        <a href="/admin/users"               @onclick="() => _adminSheetOpen = false"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="9" r="4"/><line x1="11.5" y1="11.5" x2="21" y2="21"/><line x1="21" y1="18" x2="19" y2="20"/><line x1="18" y1="21" x2="20" y2="19"/></svg> Users</a>
        <a href="/admin/groups"              @onclick="() => _adminSheetOpen = false"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="7" r="3"/><path d="M2 21v-1a6 6 0 016-6h4a6 6 0 016 6v1"/><circle cx="17" cy="7" r="2.5"/><path d="M15 21v-1a5 5 0 015-5"/></svg> Groups</a>
