@inject TransactionService TxSvc
@inject GroupService GroupSvc
@inject ISnackbar Snackbar

@if (_open)
{
    <div style="position:fixed;inset:0;background:rgba(26,26,26,.65);z-index:100;
                display:flex;align-items:center;justify-content:center;padding:20px;
                animation:fadeIn .2s ease"
         @onclick="Close">
        <div class="ccn-panel" style="padding:24px;width:100%;max-width:420px;
                                      box-shadow:8px 8px 0 var(--black);animation:popIn .25s ease"
             @onclick:stopPropagation="true">

            <div style="font-family:'Fredoka One',cursive;font-size:22px;color:var(--black);margin-bottom:18px">
                ＋ Log Transaction
            </div>

            <div style="display:flex;flex-direction:column;gap:14px">

                @* Group picker *@
                <div>
                    <div style="font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:6px">Group</div>
                    <div style="display:flex;gap:8px;flex-wrap:wrap">
                        @foreach (var g in _groups)
                        {
                            var sel = _form.GroupId == g.GroupId;
                            var s   = sel
                                ? $"font-family:'Fredoka One',cursive;font-size:13px;padding:8px 14px;border-radius:8px;cursor:pointer;background:{g.Color};color:white;border:3px solid var(--black);box-shadow:3px 3px 0 var(--black)"
                                : "font-family:'Fredoka One',cursive;font-size:13px;padding:8px 14px;border-radius:8px;cursor:pointer;background:var(--panel-bg);color:var(--black);border:3px solid var(--black);box-shadow:2px 2px 0 var(--black)";
                            <button style="@s" @onclick="() => _form.GroupId = g.GroupId">@g.ShortName</button>
                        }
                    </div>
                </div>

                @* Type picker *@
                <div>
                    <div style="font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:6px">Type</div>
                    <div style="display:flex;gap:8px">
                        @foreach (var ct in _currencyTypes)
                        {
                            var isPrimary = ct.SystemName == nameof(Currency.Primary);
                            var sel       = _form.CurrencyTypeId == ct.CurrencyTypeId;
                            var color     = isPrimary ? "var(--color-primary)" : "var(--color-accent)";
                            var textColor = isPrimary ? "var(--black)" : "white";
                            var label     = isPrimary ? "Coins" : "Stars";
                            var icon      = isPrimary ? "/img/ccn-coin.png" : "/img/ccn-star.png";
                            var s         = sel
                                ? $"flex:1;font-family:'Fredoka One',cursive;font-size:14px;padding:10px;border-radius:8px;cursor:pointer;background:{color};color:{textColor};border:3px solid var(--black);box-shadow:3px 3px 0 var(--black)"
                                : "flex:1;font-family:'Fredoka One',cursive;font-size:14px;padding:10px;border-radius:8px;cursor:pointer;background:var(--panel-bg);color:var(--black);border:3px solid var(--black);box-shadow:2px 2px 0 var(--black)";
                            <button style="@s;display:flex;align-items:center;justify-content:center;gap:8px" @onclick="() => _form.CurrencyTypeId = ct.CurrencyTypeId">
                                <img src="@icon" style="height:20px;width:auto" alt="@label" />
                                @label
                            </button>
                        }
                    </div>
                </div>

                @* Amount *@
                <div>
                    <div style="font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:6px">
                        Amount (negative = deduction)@(IsCoinsSelected ? " — multiples of 5" : "")
                    </div>
                    <input type="number" step="@(IsCoinsSelected ? "5" : "1")"
                           placeholder="@(IsCoinsSelected ? "e.g. 25 or -10 (×5 only)" : "e.g. 1 or -1")"
                           @bind="_form.Amount" @bind:event="oninput"
                           style="background:var(--bg-base);border:3px solid @(CoinAmountInvalid ? "#D12B2B" : "var(--black)");border-radius:7px;
                                  color:var(--text-dark);padding:9px 12px;font-size:14px;
                                  font-family:'Nunito',sans-serif;font-weight:700;width:100%;
                                  box-shadow:2px 2px 0 @(CoinAmountInvalid ? "#D12B2B" : "var(--black)");outline:none" />
                    @if (CoinAmountInvalid)
                    {
                        <div style="font-size:12px;font-weight:800;color:#D12B2B;margin-top:5px">
                            ⚠️ Coins must be a multiple of 5 (e.g. 5, 10, 25, -10)
                        </div>
                    }
                </div>

                @* Note *@
                <div>
                    <div style="font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:6px">Note (optional)</div>
                    <input type="text" placeholder="e.g. Won Bowser Dodge Battle" @bind="_form.Note"
                           style="background:var(--bg-base);border:3px solid var(--black);border-radius:7px;
                                  color:var(--text-dark);padding:9px 12px;font-size:14px;
                                  font-family:'Nunito',sans-serif;font-weight:700;width:100%;
                                  box-shadow:2px 2px 0 var(--black);outline:none" />
                </div>

                @* Actions *@
                <div style="display:flex;gap:10px;margin-top:4px">
                    <button class="ccn-btn" style="flex:1" @onclick="Close">Cancel</button>
                    <button class="ccn-btn" style="flex:2;background:var(--color-accent);color:white"
                            disabled="@(_submitting || CoinAmountInvalid)" @onclick="SubmitAsync">
                        @(_submitting ? "Posting..." : "Log It")
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;
    [Parameter] public EventCallback OnTransactionPosted { get; set; }

    private bool _open;
    private bool _submitting;
    private List<Group> _groups = new();
    private List<CurrencyType> _currencyTypes = new();
    private TransactionForm _form = new();

    public async Task OpenAsync()
    {
        _groups        = await GroupSvc.GetAllAsync();
        _currencyTypes = await GroupSvc.GetCurrencyTypesAsync();
        _form = new TransactionForm
        {
            CurrencyTypeId = _currencyTypes.FirstOrDefault()?.CurrencyTypeId ?? Guid.Empty
        };
        _open = true;
    }

    public async Task OpenAsync(Guid groupId, Currency currency)
    {
        _groups        = await GroupSvc.GetAllAsync();
        _currencyTypes = await GroupSvc.GetCurrencyTypesAsync();
        _form = new TransactionForm
        {
            GroupId        = groupId,
            CurrencyTypeId = _currencyTypes.FirstOrDefault(ct => ct.SystemName == currency.ToString())?.CurrencyTypeId
                             ?? _currencyTypes.FirstOrDefault()?.CurrencyTypeId
                             ?? Guid.Empty
        };
        _open = true;
    }

    private void Close() => _open = false;

    private bool IsCoinsSelected => _currencyTypes
        .FirstOrDefault(ct => ct.CurrencyTypeId == _form.CurrencyTypeId)
        ?.SystemName == nameof(Currency.Primary);

    private bool CoinAmountInvalid => IsCoinsSelected && _form.Amount != 0 && _form.Amount % 5 != 0;

    private async Task SubmitAsync()
    {
        if (_form.GroupId == Guid.Empty || _form.CurrencyTypeId == Guid.Empty || _form.Amount == 0) return;
        if (CoinAmountInvalid) return;
        _submitting = true;
        var state = await AuthState;
        var name = state.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "unknown";
        await TxSvc.PostAsync(_form.GroupId, _form.CurrencyTypeId, _form.Amount, name, _form.Note);
        Snackbar.Add("Transaction posted.", Severity.Success);
        _open = false;
        _submitting = false;
        await OnTransactionPosted.InvokeAsync();
    }

    private class TransactionForm
    {
        public Guid GroupId { get; set; }
        public Guid CurrencyTypeId { get; set; }
        public int Amount { get; set; } = 0;
        public string? Note { get; set; }
    }
}
