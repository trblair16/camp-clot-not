<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 272 52"
     style="height:@Height;width:auto;display:block;overflow:visible"
     role="img" aria-label="Camp Clot Not — Super Party 2026">

    @* CAMP CLOT NOT — per-letter Mario Party palette, black outline *@
    <text x="2" y="36"
          font-family="'Fredoka One', cursive"
          font-size="32"
          paint-order="stroke fill"
          stroke="#1A1A1A"
          stroke-width="2"
          stroke-linejoin="round">
        <tspan fill="#D12B2B">C</tspan><tspan fill="#2563C4">A</tspan><tspan fill="#2B8A3E">M</tspan><tspan fill="#D12B2B">P</tspan>
        <tspan dx="9" fill="#F5C800">C</tspan><tspan fill="#2B8A3E">L</tspan><tspan fill="#2563C4">O</tspan><tspan fill="#F5C800">T</tspan>
        <tspan dx="9" fill="#2563C4">N</tspan><tspan fill="#F5C800">O</tspan><tspan fill="#D12B2B">T</tspan>
    </text>

    @* Subtitle *@
    <text x="3" y="50"
          font-family="'Nunito', sans-serif"
          font-size="10"
          font-weight="800"
          fill="rgba(255,255,255,0.6)"
          letter-spacing="2">SUPER PARTY '26</text>

</svg>

@code {
    [Parameter] public string Height { get; set; } = "40px";
}
