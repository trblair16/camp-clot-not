@page "/bowser/display"
@attribute [Authorize(Roles = "Admin")]
@layout DisplayLayout
@inject NavigationManager Nav
@using Microsoft.AspNetCore.SignalR.Client

<PageTitle>Bowser Event — Display</PageTitle>

<style>
    .bowser-bg {
        min-height: 100vh;
        background: linear-gradient(135deg, #1a0a0a 0%, #4a0e0e 50%, #1a0a0a 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 32px;
        color: white;
        font-family: 'Fredoka One', cursive;
        position: relative;
        overflow: hidden;
    }
    .flame {
        position: absolute;
        bottom: -20px;
        width: 60px;
        height: 120px;
        border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
        opacity: .5;
        filter: blur(8px);
        animation: flicker 1.5s ease-in-out infinite alternate;
        pointer-events: none;
    }
    .flame:nth-child(1)  { left: 3%;  width: 50px; height: 100px; background: #E83030; animation-delay: 0s; animation-duration: 1.2s; }
    .flame:nth-child(2)  { left: 10%; width: 40px; height: 130px; background: #F5C800; animation-delay: .3s; animation-duration: 1.8s; }
    .flame:nth-child(3)  { left: 18%; width: 55px; height: 110px; background: #E67E22; animation-delay: .6s; animation-duration: 1.4s; }
    .flame:nth-child(4)  { left: 28%; width: 45px; height: 140px; background: #E83030; animation-delay: .1s; animation-duration: 1.6s; }
    .flame:nth-child(5)  { left: 40%; width: 60px; height: 100px; background: #F5C800; animation-delay: .8s; animation-duration: 1.3s; }
    .flame:nth-child(6)  { left: 52%; width: 50px; height: 120px; background: #E67E22; animation-delay: .4s; animation-duration: 1.7s; }
    .flame:nth-child(7)  { left: 62%; width: 55px; height: 135px; background: #E83030; animation-delay: .2s; animation-duration: 1.5s; }
    .flame:nth-child(8)  { left: 72%; width: 40px; height: 105px; background: #F5C800; animation-delay: .7s; animation-duration: 1.1s; }
    .flame:nth-child(9)  { left: 82%; width: 50px; height: 125px; background: #E67E22; animation-delay: .5s; animation-duration: 1.9s; }
    .flame:nth-child(10) { left: 92%; width: 45px; height: 115px; background: #E83030; animation-delay: .9s; animation-duration: 1.4s; }
    @@keyframes flicker {
        0%   { transform: scaleY(1) scaleX(1) translateY(0); opacity: .4; }
        50%  { transform: scaleY(1.3) scaleX(.9) translateY(-20px); opacity: .7; }
        100% { transform: scaleY(.8) scaleX(1.1) translateY(-10px); opacity: .5; }
    }
    .bowser-title {
        font-size: clamp(28px, 5vw, 48px);
        color: #F5C800;
        text-shadow: 3px 3px 0 #1A1A1A;
        margin-bottom: 32px;
        text-align: center;
    }
    .bowser-group {
        font-size: clamp(24px, 4vw, 40px);
        margin-bottom: 24px;
        text-shadow: 2px 2px 0 rgba(0,0,0,.5);
    }
    .bowser-die-container {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        max-width: 500px;
        width: 100%;
        margin-bottom: 32px;
    }
    .bowser-face {
        border: 4px solid rgba(255,255,255,.2);
        border-radius: 12px;
        padding: 16px 12px;
        text-align: center;
        font-size: 14px;
        background: rgba(255,255,255,.05);
        transition: all .3s ease;
    }
    .bowser-face.cycling {
        animation: bowserPulse .15s ease infinite alternate;
    }
    .bowser-face.selected {
        border-color: #F5C800;
        background: rgba(245,200,0,.2);
        box-shadow: 0 0 30px rgba(245,200,0,.4);
        transform: scale(1.08);
    }
    .bowser-face .face-emoji { font-size: 32px; display: block; margin-bottom: 6px; }
    .bowser-face .face-label { font-family: 'Fredoka One', cursive; font-size: 16px; }
    .bowser-result {
        font-size: clamp(20px, 3.5vw, 36px);
        text-align: center;
        margin-top: 16px;
        animation: popIn .3s ease;
    }
    .bowser-idle {
        font-size: clamp(32px, 6vw, 56px);
        color: #F5C800;
        text-shadow: 3px 3px 0 #1A1A1A;
    }
    @@keyframes bowserPulse { from { opacity: .4; } to { opacity: 1; } }
</style>

<div class="bowser-bg">
    <div class="flame"></div><div class="flame"></div><div class="flame"></div>
    <div class="flame"></div><div class="flame"></div><div class="flame"></div>
    <div class="flame"></div><div class="flame"></div><div class="flame"></div>
    <div class="flame"></div>
    <img src="/img/bowser-space.webp" style="width:80px;height:80px;border-radius:50%;border:4px solid #F5C800;margin-bottom:16px;object-fit:cover" alt="" />
    <div class="bowser-title">BOWSER EVENT</div>

    @if (_state == DisplayState.Idle)
    {
        <div class="bowser-idle">Waiting for roll...</div>
    }
    else
    {
        <div class="bowser-group" style="color:@_groupColor">@_groupName</div>

        <div class="bowser-die-container">
            @for (int i = 0; i < _faces.Length; i++)
            {
                var face = _faces[i];
                var isCycling = _state == DisplayState.Rolling && _highlightIndex == i;
                var isSelected = _state == DisplayState.Revealed && _revealedIndex == i;
                <div class="bowser-face @(isCycling ? "cycling" : "") @(isSelected ? "selected" : "")">
                    <span class="face-emoji">@face.Emoji</span>
                    <span class="face-label">@face.Label</span>
                </div>
            }
        </div>

        @if (_state == DisplayState.Revealed)
        {
            <div class="bowser-result">
                <div style="font-size:48px;margin-bottom:8px">@_faces[_revealedIndex].Emoji</div>
                <div>@_resultDescription</div>
            </div>
        }
    }
</div>

@code {
    private enum DisplayState { Idle, Rolling, Revealed }

    private record DisplayFace(string Emoji, string Label);

    private DisplayState _state = DisplayState.Idle;
    private string _groupName = "";
    private string _groupColor = "white";
    private int _highlightIndex;
    private int _revealedIndex;
    private string _resultDescription = "";
    private DisplayFace[] _faces = BowserEventService.DefaultFaces.Select(f => new DisplayFace(f.Emoji, f.Label)).ToArray();
    private HubConnection? _hub;
    private CancellationTokenSource? _cycleCts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/livehub"))
            .WithAutomaticReconnect()
            .Build();

        _hub.On<Guid, string, string, object[]>("BowserRollStarted", async (groupId, name, color, facesPayload) =>
        {
            _groupName = name;
            _groupColor = color;
            try
            {
                var json = System.Text.Json.JsonSerializer.Serialize(facesPayload);
                var parsed = System.Text.Json.JsonSerializer.Deserialize<DisplayFace[]>(json);
                if (parsed is { Length: > 0 }) _faces = parsed;
            }
            catch { }
            _state = DisplayState.Rolling;
            _cycleCts = new CancellationTokenSource();
            await InvokeAsync(StateHasChanged);
            _ = CycleAsync(_cycleCts.Token);
        });

        _hub.On<Guid, int, string, string>("BowserRollResult", async (groupId, faceIndex, label, description) =>
        {
            _cycleCts?.Cancel();
            _revealedIndex = faceIndex;
            _resultDescription = description;
            _state = DisplayState.Revealed;
            await InvokeAsync(StateHasChanged);
        });

        _hub.On("BowserReset", async () =>
        {
            _cycleCts?.Cancel();
            _state = DisplayState.Idle;
            _groupName = "";
            _groupColor = "white";
            _faces = BowserEventService.DefaultFaces.Select(f => new DisplayFace(f.Emoji, f.Label)).ToArray();
            await InvokeAsync(StateHasChanged);
        });

        await _hub.StartAsync();
    }

    private async Task CycleAsync(CancellationToken ct)
    {
        var rng = new Random();
        while (!ct.IsCancellationRequested)
        {
            _highlightIndex = rng.Next(_faces.Length);
            await InvokeAsync(StateHasChanged);
            try { await Task.Delay(120, ct); } catch { break; }
        }
    }
}
