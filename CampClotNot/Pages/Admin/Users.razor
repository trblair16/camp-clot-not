@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@inject AuthService AuthSvc
@inject GroupService GroupSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using CampClotNot.Data.Entities

<PageTitle>Manage Users — Camp Clot Not</PageTitle>

<div style="padding: 0 16px 100px">
    <h2 style="font-family:'Fredoka One',cursive;font-size:22px;margin:0 0 20px">👤 User Accounts</h2>

    <div style="display:flex;gap:20px;align-items:flex-start;flex-wrap:wrap">

        @* ── Create Account form ── *@
        <div style="background:var(--panel-bg);border:3px solid var(--black);border-radius:10px;box-shadow:4px 4px 0 var(--black);padding:20px;flex:0 0 320px;min-width:260px">
            <h3 style="font-family:'Fredoka One',cursive;font-size:16px;margin:0 0 16px">Create Account</h3>

            <div style="display:flex;gap:10px;margin-bottom:14px">
                <div style="flex:1">
                    <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">First Name</div>
                    <input type="text" @bind="_form.FirstName" placeholder="First"
                           style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
                </div>
                <div style="flex:1">
                    <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Last Name</div>
                    <input type="text" @bind="_form.LastName" placeholder="Last"
                           style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
                </div>
            </div>

            <div style="margin-bottom:14px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Email</div>
                <input type="email" @bind="_form.Email" placeholder="you@example.com"
                       style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
            </div>

            <div style="margin-bottom:14px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Temporary Password</div>
                <input type="password" @bind="_form.Password" placeholder="••••••••"
                       style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
            </div>

            <div style="margin-bottom:14px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Role</div>
                <select value="@_form.Role.ToString()"
                        @onchange="e => _form.Role = Enum.Parse<Role>(e.Value?.ToString() ?? nameof(Role.Staff))"
                        style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box;cursor:pointer">
                    <option value="Staff">Staff</option>
                    <option value="Volunteer">Volunteer / Counselor</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>

            @if (_form.Role == Role.Volunteer)
            {
                <div style="margin-bottom:14px">
                    <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Assigned Group</div>
                    <select value="@(_form.GroupId?.ToString() ?? "")"
                            @onchange="e => _form.GroupId = Guid.TryParse(e.Value?.ToString(), out var gid) ? gid : null"
                            style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box;cursor:pointer">
                        <option value="">— None —</option>
                        @foreach (var g in _groups)
                        {
                            <option value="@g.GroupId">@g.Name</option>
                        }
                    </select>
                </div>
            }

            <button class="ccn-btn" style="width:100%;margin-top:4px" @onclick="CreateAsync">Create Account</button>
        </div>

        @* ── Users table ── *@
        <div style="flex:1;min-width:260px">
            @if (_loading)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (!_users.Any())
            {
                <p style="color:var(--text-light);font-family:'Fredoka One',cursive">No users yet.</p>
            }
            else
            {
                <div style="border:3px solid var(--black);border-radius:10px;box-shadow:4px 4px 0 var(--black);overflow:hidden">
                    <div style="overflow-x:auto">
                        <table style="width:100%;border-collapse:collapse;min-width:600px">
                            <thead>
                                <tr style="background:var(--black)">
                                    <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Name</th>
                                    <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Email</th>
                                    <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Role</th>
                                    <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Group</th>
                                    <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Active</th>
                                    <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var u in _users)
                                {
                                    <tr style="border-bottom:2px solid #E8E0CC">
                                        <td style="padding:10px 14px;font-size:13px;font-weight:700">@u.FirstName @u.LastName</td>
                                        <td style="padding:10px 14px;font-size:12px;color:var(--text-mid)">@u.Email</td>
                                        <td style="padding:10px 14px">
                                            <span style="background:var(--black);color:white;font-family:'Fredoka One',cursive;font-size:11px;padding:2px 8px;border-radius:4px">@u.UserRole.SystemName</span>
                                        </td>
                                        <td style="padding:10px 14px;font-size:13px">@(_groups.FirstOrDefault(g => g.GroupId == u.GroupId)?.ShortName ?? "—")</td>
                                        <td style="padding:10px 14px;font-size:13px">@(u.IsActive ? "✓" : "—")</td>
                                        <td style="padding:8px 10px">
                                            <div style="display:flex;gap:4px;flex-wrap:wrap">
                                                <button class="ccn-btn" style="font-size:11px;padding:4px 10px" @onclick="() => OpenEditDialog(u)">Edit</button>
                                                <button class="ccn-btn" style="font-size:11px;padding:4px 10px" @onclick="() => OpenResetDialog(u)">Reset PW</button>
                                                @if (u.IsActive)
                                                {
                                                    <button class="ccn-btn" style="font-size:11px;padding:4px 10px;background:#E67E22;color:white" @onclick="() => DeactivateAsync(u)">Deactivate</button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

    </div>
</div>

@* ── Edit User modal ── *@
@if (_editOpen)
{
    <div style="position:fixed;inset:0;background:rgba(26,26,26,.6);z-index:100;display:flex;align-items:center;justify-content:center;padding:16px;animation:fadeIn .15s ease"
         @onclick="CloseEditDialog">
        <div style="background:var(--panel-bg);border:3px solid var(--black);border-radius:12px;box-shadow:6px 6px 0 var(--black);padding:24px;width:100%;max-width:440px;animation:popIn .2s ease"
             @onclick:stopPropagation>
            <h3 style="font-family:'Fredoka One',cursive;font-size:18px;margin:0 0 18px">Edit User</h3>

            <div style="display:flex;gap:10px;margin-bottom:14px">
                <div style="flex:1">
                    <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">First Name</div>
                    <input type="text" @bind="_editForm.FirstName" placeholder="First"
                           style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
                </div>
                <div style="flex:1">
                    <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Last Name</div>
                    <input type="text" @bind="_editForm.LastName" placeholder="Last"
                           style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
                </div>
            </div>

            <div style="margin-bottom:14px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Email</div>
                <input type="email" @bind="_editForm.Email" placeholder="you@example.com"
                       style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
            </div>

            <div style="margin-bottom:14px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Role</div>
                <select value="@_editForm.Role.ToString()"
                        @onchange="e => _editForm.Role = Enum.Parse<Role>(e.Value?.ToString() ?? nameof(Role.Staff))"
                        style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box;cursor:pointer">
                    <option value="Staff">Staff</option>
                    <option value="Volunteer">Volunteer / Counselor</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>

            @if (_editForm.Role == Role.Volunteer)
            {
                <div style="margin-bottom:14px">
                    <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Assigned Group</div>
                    <select value="@(_editForm.GroupId?.ToString() ?? "")"
                            @onchange="e => _editForm.GroupId = Guid.TryParse(e.Value?.ToString(), out var gid) ? gid : null"
                            style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box;cursor:pointer">
                        <option value="">— None —</option>
                        @foreach (var g in _groups)
                        {
                            <option value="@g.GroupId">@g.Name</option>
                        }
                    </select>
                </div>
            }

            @if (_editError is not null)
            {
                <div style="background:#FEE2E2;border:2px solid #E83030;border-radius:7px;padding:8px 12px;margin-bottom:14px;font-size:13px;font-weight:700;color:#C0392B">⚠️ @_editError</div>
            }

            <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:4px">
                <button class="ccn-btn" style="background:transparent" @onclick="CloseEditDialog">Cancel</button>
                <button class="ccn-btn" @onclick="SubmitEditAsync">Save Changes</button>
            </div>
        </div>
    </div>
}

@* ── Reset Password modal ── *@
@if (_resetOpen)
{
    <div style="position:fixed;inset:0;background:rgba(26,26,26,.6);z-index:100;display:flex;align-items:center;justify-content:center;padding:16px;animation:fadeIn .15s ease"
         @onclick="CloseResetDialog">
        <div style="background:var(--panel-bg);border:3px solid var(--black);border-radius:12px;box-shadow:6px 6px 0 var(--black);padding:24px;width:100%;max-width:400px;animation:popIn .2s ease"
             @onclick:stopPropagation>
            <h3 style="font-family:'Fredoka One',cursive;font-size:18px;margin:0 0 18px">Reset Password</h3>
            <p style="font-size:13px;color:var(--text-light);margin:0 0 16px">@_resetting?.FirstName @_resetting?.LastName</p>

            <div style="margin-bottom:14px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">New Password</div>
                <input type="password" @bind="_resetPassword" placeholder="••••••••"
                       style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
            </div>

            <div style="margin-bottom:14px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Confirm Password</div>
                <input type="password" @bind="_resetConfirm" placeholder="••••••••"
                       style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
            </div>

            @if (_resetError is not null)
            {
                <div style="background:#FEE2E2;border:2px solid #E83030;border-radius:7px;padding:8px 12px;margin-bottom:14px;font-size:13px;font-weight:700;color:#C0392B">⚠️ @_resetError</div>
            }

            <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:4px">
                <button class="ccn-btn" style="background:transparent" @onclick="CloseResetDialog">Cancel</button>
                <button class="ccn-btn" @onclick="SubmitResetAsync">Reset Password</button>
            </div>
        </div>
    </div>
}

@code {
    private List<User> _users = new();
    private List<Group> _groups = new();
    private bool _loading = true;
    private UserForm _form = new();

    private bool _editOpen;
    private User? _editing;
    private EditUserForm _editForm = new();
    private string? _editError;

    private bool _resetOpen;
    private User? _resetting;
    private string _resetPassword = "";
    private string _resetConfirm = "";
    private string? _resetError;

    protected override async Task OnInitializedAsync()
    {
        _groups = await GroupSvc.GetAllAsync();
        _users  = await AuthSvc.GetAllUsersAsync();
        _loading = false;
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Email) || string.IsNullOrWhiteSpace(_form.Password)) return;
        var groupId = _form.Role == Role.Volunteer ? _form.GroupId : null;
        await AuthSvc.CreateUserAsync(_form.FirstName, _form.LastName, _form.Email, _form.Password, _form.Role, groupId);
        Snackbar.Add($"Account created for {_form.FirstName} {_form.LastName}.", Severity.Success);
        _form = new();
        _users = await AuthSvc.GetAllUsersAsync();
    }

    private void OpenEditDialog(User u)
    {
        _editing = u;
        _editForm = new EditUserForm
        {
            FirstName = u.FirstName,
            LastName  = u.LastName,
            Email     = u.Email,
            Role      = Enum.TryParse<Role>(u.UserRole.SystemName, out var r) ? r : Role.Staff,
            GroupId   = u.GroupId
        };
        _editError = null;
        _editOpen = true;
    }

    private void CloseEditDialog()
    {
        _editOpen = false;
        _editing = null;
    }

    private async Task SubmitEditAsync()
    {
        if (string.IsNullOrWhiteSpace(_editForm.FirstName) || string.IsNullOrWhiteSpace(_editForm.Email))
        {
            _editError = "First name and email are required.";
            return;
        }
        var groupId = _editForm.Role == Role.Volunteer ? _editForm.GroupId : null;
        await AuthSvc.UpdateUserAsync(_editing!.UserId, _editForm.FirstName, _editForm.LastName, _editForm.Email, _editForm.Role, groupId);
        Snackbar.Add($"{_editForm.FirstName} {_editForm.LastName} updated.", Severity.Success);
        _users = await AuthSvc.GetAllUsersAsync();
        CloseEditDialog();
    }

    private void OpenResetDialog(User u)
    {
        _resetting = u;
        _resetPassword = "";
        _resetConfirm = "";
        _resetError = null;
        _resetOpen = true;
    }

    private void CloseResetDialog()
    {
        _resetOpen = false;
        _resetting = null;
    }

    private async Task SubmitResetAsync()
    {
        if (string.IsNullOrWhiteSpace(_resetPassword))
        {
            _resetError = "Password cannot be empty.";
            return;
        }
        if (_resetPassword != _resetConfirm)
        {
            _resetError = "Passwords do not match.";
            return;
        }
        await AuthSvc.ResetPasswordAsync(_resetting!.UserId, _resetPassword);
        Snackbar.Add($"Password reset for {_resetting.FirstName} {_resetting.LastName}.", Severity.Success);
        CloseResetDialog();
    }

    private async Task DeactivateAsync(User u)
    {
        var result = await DialogService.ShowMessageBox("Deactivate User",
            $"Deactivate {u.FirstName} {u.LastName}? They will no longer be able to sign in.",
            yesText: "Deactivate", cancelText: "Cancel");
        if (result != true) return;
        await AuthSvc.DeactivateUserAsync(u.UserId);
        _users = await AuthSvc.GetAllUsersAsync();
        Snackbar.Add($"{u.FirstName} {u.LastName} deactivated.", Severity.Info);
    }

    private class UserForm
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public Role Role { get; set; } = Role.Staff;
        public Guid? GroupId { get; set; }
    }

    private class EditUserForm
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public Role Role { get; set; } = Role.Staff;
        public Guid? GroupId { get; set; }
    }
}
