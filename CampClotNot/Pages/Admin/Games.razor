@page "/admin/games"
@attribute [Authorize(Roles = "Admin")]
@inject BoardService BoardSvc
@inject MiniGameService MiniGameSvc
@inject GroupService GroupSvc

<PageTitle>Game Admin — Camp Clot Not</PageTitle>

<style>
    @@media (max-width: 699px) {
        .admin-gm-table   { display: none; }
        .admin-gm-cards   { display: flex; flex-direction: column; gap: 10px; }
        .admin-mg-table   { display: none; }
        .admin-mg-cards   { display: flex; flex-direction: column; gap: 10px; }
    }
    @@media (min-width: 700px) {
        .admin-gm-cards { display: none; }
        .admin-mg-cards { display: none; }
    }
</style>

<div style="padding: 0 16px 100px">
    <h2 style="font-family:'Fredoka One',cursive;font-size:22px;margin:0 0 20px"><img src="/img/icons/game.svg?v=2" style="width:20px;height:20px;vertical-align:middle;margin-right:6px;opacity:.8" alt="" />Game Admin</h2>

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

        @* ── TAB 1: BOARD SPACES ───────────────────────────────────────────────── *@
        <MudTabPanel Text="Board Spaces">
            <p style="font-size:13px;color:var(--text-light);margin:0 0 16px">
                20-space layout seeded from mockup. Adjust XPos/YPos in SeedService and restart to reposition.
            </p>

            @if (_spaces is null)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else
            {
                <div class="admin-gm-cards">
                    @foreach (var space in _spaces)
                    {
                        <div style="background:var(--panel-bg);border:3px solid var(--black);border-radius:10px;box-shadow:3px 3px 0 var(--black);padding:10px 14px;display:flex;align-items:center;gap:10px">
                            <div style="font-family:'Fredoka One',cursive;font-size:20px;color:var(--text-light);min-width:28px;text-align:center">@space.SpaceIndex</div>
                            <div style="flex:1;min-width:0">
                                <span style="@($"background:{SpaceColor(space.CategorySystemName)};color:white;font-family:'Fredoka One',cursive;font-size:11px;padding:2px 8px;border-radius:4px")">
                                    @SpaceIcon(space.CategorySystemName) @space.CategorySystemName
                                </span>
                                @if (!string.IsNullOrEmpty(space.ActivityName))
                                {
                                    <div style="font-size:13px;font-weight:700;margin-top:4px">@space.ActivityName</div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="admin-gm-table" style="border:3px solid var(--black);border-radius:10px;box-shadow:4px 4px 0 var(--black);overflow:hidden">
                    <table style="width:100%;border-collapse:collapse">
                        <thead>
                            <tr style="background:var(--black)">
                                <th style="@ThStyle()">#</th>
                                <th style="@ThStyle()">Type</th>
                                <th style="@ThStyle()">Activity</th>
                                <th style="@ThStyle()">X</th>
                                <th style="@ThStyle()">Y</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var space in _spaces)
                            {
                                <tr style="border-bottom:2px solid #E8E0CC">
                                    <td style="@TdStyle()">@space.SpaceIndex</td>
                                    <td style="@TdStyle()">
                                        <span style="@($"background:{SpaceColor(space.CategorySystemName)};color:white;font-family:'Fredoka One',cursive;font-size:11px;padding:2px 8px;border-radius:4px")">
                                            @SpaceIcon(space.CategorySystemName) @space.CategorySystemName
                                        </span>
                                    </td>
                                    <td style="@TdStyle()">@space.ActivityName</td>
                                    <td style="@TdStyle()">@space.XPos</td>
                                    <td style="@TdStyle()">@space.YPos</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </MudTabPanel>

        @* ── TAB 2: BLOCK HIT SCRIPTS ──────────────────────────────────────────── *@
        <MudTabPanel Text="Block Hit Scripts">
            <p style="font-size:13px;color:var(--text-light);margin:0 0 16px">
                Set the destination space for each group per camp day. Cannot edit after triggered.
            </p>

            @if (_groups is null || _blockHitScripts is null)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else
            {
                <div style="border:3px solid var(--black);border-radius:10px;box-shadow:4px 4px 0 var(--black);overflow:hidden">
                    <div style="overflow-x:auto">
                        <table style="border-collapse:collapse;width:100%;min-width:480px">
                            <thead>
                                <tr style="background:var(--black)">
                                    <th style="@ThStyle()">Group</th>
                                    @for (var d = 1; d <= 5; d++)
                                    {
                                        <th style="@ThStyle()">Day @d</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var group in _groups)
                                {
                                    <tr style="border-bottom:2px solid #E8E0CC">
                                        <td style="@TdStyle()">
                                            <div style="display:flex;align-items:center;gap:8px">
                                                <div style="@($"width:12px;height:12px;border-radius:50%;background:{group.Color};flex-shrink:0")"></div>
                                                <span style="font-weight:700;font-size:13px">@group.ShortName</span>
                                                <span style="color:var(--text-light);font-size:12px">@group.Name</span>
                                            </div>
                                        </td>
                                        @for (var day = 1; day <= 5; day++)
                                        {
                                            var d = day;
                                            var script = _blockHitScripts.FirstOrDefault(s => s.GroupId == group.GroupId && s.CampDay == d);
                                            <td style="@TdStyle()">
                                                @if (script?.IsTriggered == true)
                                                {
                                                    <span style="background:#27AE60;color:white;font-family:'Fredoka One',cursive;font-size:11px;padding:2px 8px;border-radius:4px">✓ @script.DestinationSpaceIndex</span>
                                                }
                                                else
                                                {
                                                    <input type="number" min="0" max="19" placeholder="—"
                                                           value="@(script?.DestinationSpaceIndex.ToString() ?? "")"
                                                           @onchange="async e => { if (int.TryParse(e.Value?.ToString(), out var v)) await OnBlockHitDestChanged(group.GroupId, d, v); }"
                                                           style="width:70px;padding:6px 8px;background:var(--bg-base);border:2px solid var(--black);border-radius:6px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:700;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;text-align:center;box-sizing:border-box" />
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @if (_blockHitSaveMsg is not null)
                {
                    <div style="margin-top:12px;padding:10px 16px;border:2px solid var(--black);border-radius:8px;background:#E8F5E9;font-family:'Fredoka One',cursive;font-size:13px">✓ @_blockHitSaveMsg</div>
                }
            }
        </MudTabPanel>

        @* ── TAB 3: MINI-GAME SCRIPTS ──────────────────────────────────────────── *@
        <MudTabPanel Text="Mini-Game Scripts">
            <p style="font-size:13px;color:var(--text-light);margin:0 0 16px">
                Set the activity revealed for each camp day's evening mini-game. Cannot edit after triggered.
            </p>

            @if (_miniGameActivities is null || _miniGameScripts is null)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (_miniGameActivities.Count == 0)
            {
                <div style="padding:14px 16px;border:2px solid var(--black);border-radius:8px;background:#E3F2FD;font-size:13px">
                    ℹ️ No MinuteToWinIt activities seeded yet. Add activities with category "MinuteToWinIt" in SeedService and restart.
                </div>
            }
            else
            {
                <div class="admin-mg-cards">
                    @for (var day = 1; day <= 5; day++)
                    {
                        var d = day;
                        var script = _miniGameScripts.FirstOrDefault(s => s.CampDay == d);
                        <div style="background:var(--panel-bg);border:3px solid var(--black);border-radius:10px;box-shadow:3px 3px 0 var(--black);padding:12px 14px">
                            <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:8px">
                                <div style="font-family:'Fredoka One',cursive;font-size:15px;color:var(--black)">Day @d</div>
                                @if (script?.IsTriggered == true)
                                {
                                    <span style="background:#27AE60;color:white;font-family:'Fredoka One',cursive;font-size:11px;padding:2px 8px;border-radius:4px">✓ Triggered</span>
                                }
                                else if (script is not null)
                                {
                                    <span style="background:#E67E22;color:white;font-family:'Fredoka One',cursive;font-size:11px;padding:2px 8px;border-radius:4px">Scripted</span>
                                }
                                else
                                {
                                    <span style="background:#95A5A6;color:white;font-family:'Fredoka One',cursive;font-size:11px;padding:2px 8px;border-radius:4px">Not set</span>
                                }
                            </div>
                            @if (script?.IsTriggered == true)
                            {
                                <div style="font-size:13px;color:var(--text-mid)">@script.ActivityName</div>
                            }
                            else
                            {
                                <select value="@(script?.ActivityId.ToString() ?? "")"
                                        @onchange="async e => { if (Guid.TryParse(e.Value?.ToString(), out var g)) await OnMiniGameActivityChanged(d, g); }"
                                        style="width:100%;padding:7px 10px;background:var(--bg-base);border:2px solid var(--black);border-radius:6px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;cursor:pointer;box-sizing:border-box">
                                    <option value="">— pick activity —</option>
                                    @foreach (var activity in _miniGameActivities)
                                    {
                                        <option value="@activity.ActivityId">@activity.Name</option>
                                    }
                                </select>
                            }
                        </div>
                    }
                </div>

                <div class="admin-mg-table" style="border:3px solid var(--black);border-radius:10px;box-shadow:4px 4px 0 var(--black);overflow:hidden;max-width:640px">
                    <table style="border-collapse:collapse;width:100%">
                        <thead>
                            <tr style="background:var(--black)">
                                <th style="@ThStyle()">Camp Day</th>
                                <th style="@ThStyle()">Activity</th>
                                <th style="@ThStyle()">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var day = 1; day <= 5; day++)
                            {
                                var d = day;
                                var script = _miniGameScripts.FirstOrDefault(s => s.CampDay == d);
                                <tr style="border-bottom:2px solid #E8E0CC">
                                    <td style="@TdStyle()"><span style="font-weight:700">Day @d</span></td>
                                    <td style="@TdStyle()">
                                        @if (script?.IsTriggered == true)
                                        {
                                            <span style="font-size:13px;color:var(--text-light)">@script.ActivityName</span>
                                        }
                                        else
                                        {
                                            <select value="@(script?.ActivityId.ToString() ?? "")"
                                                    @onchange="async e => { if (Guid.TryParse(e.Value?.ToString(), out var g)) await OnMiniGameActivityChanged(d, g); }"
                                                    style="min-width:200px;padding:7px 10px;background:var(--bg-base);border:2px solid var(--black);border-radius:6px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;cursor:pointer;box-sizing:border-box">
                                                <option value="">— pick activity —</option>
                                                @foreach (var activity in _miniGameActivities)
                                                {
                                                    <option value="@activity.ActivityId">@activity.Name</option>
                                                }
                                            </select>
                                        }
                                    </td>
                                    <td style="@TdStyle()">
                                        @if (script?.IsTriggered == true)
                                        {
                                            <span style="background:#27AE60;color:white;font-family:'Fredoka One',cursive;font-size:11px;padding:2px 8px;border-radius:4px">✓ Triggered</span>
                                        }
                                        else if (script is not null)
                                        {
                                            <span style="background:#E67E22;color:white;font-family:'Fredoka One',cursive;font-size:11px;padding:2px 8px;border-radius:4px">Scripted</span>
                                        }
                                        else
                                        {
                                            <span style="background:#95A5A6;color:white;font-family:'Fredoka One',cursive;font-size:11px;padding:2px 8px;border-radius:4px">Not set</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (_miniGameSaveMsg is not null)
                {
                    <div style="margin-top:12px;padding:10px 16px;border:2px solid var(--black);border-radius:8px;background:#E8F5E9;font-family:'Fredoka One',cursive;font-size:13px">✓ @_miniGameSaveMsg</div>
                }
            }
        </MudTabPanel>

        @* ── TAB 4: RESET (dev/testing) ────────────────────────────────────────── *@
        <MudTabPanel Text="Reset">
            <p style="font-size:13px;color:var(--text-light);margin:0 0 20px">
                Testing utilities — reset scripted sequences so animations can be re-run.
            </p>

            <div style="display:flex;flex-direction:column;gap:16px;max-width:480px">

                <div style="background:var(--panel-bg);border:3px solid var(--black);border-radius:10px;box-shadow:4px 4px 0 var(--black);padding:20px">
                    <h3 style="font-family:'Fredoka One',cursive;font-size:15px;margin:0 0 6px">Block Hit — Reset Day</h3>
                    <p style="font-size:13px;color:var(--text-light);margin:0 0 14px">Moves all groups back to space 0 and un-triggers all block hit scripts for the selected day.</p>
                    <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                        <div>
                            <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Camp Day</div>
                            <input type="number" @bind="_resetDay" min="1" max="5"
                                   style="width:90px;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:700;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box;text-align:center" />
                        </div>
                        <button class="ccn-btn" style="background:var(--color-accent);color:white;margin-top:18px"
                                disabled="@_resettingBoard" @onclick="ResetBoardDayAsync">
                            @(_resettingBoard ? "Resetting…" : "⟳ Reset Board Day")
                        </button>
                    </div>
                    @if (_resetBoardMsg is not null)
                    {
                        <div style="margin-top:12px;padding:8px 14px;border:2px solid var(--black);border-radius:7px;background:#FFF8E1;font-family:'Fredoka One',cursive;font-size:13px">@_resetBoardMsg</div>
                    }
                </div>

                <div style="background:var(--panel-bg);border:3px solid var(--black);border-radius:10px;box-shadow:4px 4px 0 var(--black);padding:20px">
                    <h3 style="font-family:'Fredoka One',cursive;font-size:15px;margin:0 0 6px">Mini-Game — Reset Day</h3>
                    <p style="font-size:13px;color:var(--text-light);margin:0 0 14px">Un-triggers the mini-game script for the selected day so the spinner can be re-run.</p>
                    <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                        <div>
                            <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Camp Day</div>
                            <input type="number" @bind="_resetMiniGameDay" min="1" max="5"
                                   style="width:90px;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:700;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box;text-align:center" />
                        </div>
                        <button class="ccn-btn" style="background:var(--color-accent);color:white;margin-top:18px"
                                disabled="@_resettingMiniGame" @onclick="ResetMiniGameDayAsync">
                            @(_resettingMiniGame ? "Resetting…" : "⟳ Reset Mini-Game Day")
                        </button>
                    </div>
                    @if (_resetMiniGameMsg is not null)
                    {
                        <div style="margin-top:12px;padding:8px 14px;border:2px solid var(--black);border-radius:7px;background:#FFF8E1;font-family:'Fredoka One',cursive;font-size:13px">@_resetMiniGameMsg</div>
                    }
                </div>

            </div>
        </MudTabPanel>

    </MudTabs>
</div>

@code {
    private List<BoardSpaceView>?      _spaces;
    private List<Group>?               _groups;
    private List<ScriptedBlockHit>?    _blockHitScripts;
    private List<Activity>?            _miniGameActivities;
    private List<MiniGameScriptView>?  _miniGameScripts;

    private string? _blockHitSaveMsg;
    private string? _miniGameSaveMsg;

    private int     _resetDay        = 1;
    private bool    _resettingBoard;
    private string? _resetBoardMsg;

    private int     _resetMiniGameDay  = 1;
    private bool    _resettingMiniGame;
    private string? _resetMiniGameMsg;

    private static readonly Guid EventId = SeedService.Id.EventCcn2026;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadBoardDataAsync(),
            LoadMiniGameDataAsync()
        );
    }

    private async Task LoadBoardDataAsync()
    {
        _spaces          = await BoardSvc.GetSpacesAsync(EventId);
        _groups          = await GroupSvc.GetAllAsync();
        _blockHitScripts = await BoardSvc.GetScriptedBlockHitsAsync(EventId);
    }

    private async Task LoadMiniGameDataAsync()
    {
        _miniGameActivities = await MiniGameSvc.GetActivitiesAsync(EventId);
        _miniGameScripts    = await MiniGameSvc.GetScriptsAsync(EventId);
    }

    private async Task OnBlockHitDestChanged(Guid groupId, int campDay, int? destination)
    {
        if (destination is null) return;
        await BoardSvc.UpsertScriptAsync(groupId, EventId, campDay, destination.Value);
        _blockHitScripts = await BoardSvc.GetScriptedBlockHitsAsync(EventId);
        _blockHitSaveMsg = $"Day {campDay} destination saved.";
        StateHasChanged();
        await Task.Delay(2500);
        _blockHitSaveMsg = null;
        StateHasChanged();
    }

    private async Task OnMiniGameActivityChanged(int campDay, Guid? activityId)
    {
        if (activityId is null) return;
        await MiniGameSvc.UpsertScriptAsync(EventId, campDay, activityId.Value);
        _miniGameScripts = await MiniGameSvc.GetScriptsAsync(EventId);
        _miniGameSaveMsg = $"Day {campDay} mini-game saved.";
        StateHasChanged();
        await Task.Delay(2500);
        _miniGameSaveMsg = null;
        StateHasChanged();
    }

    private async Task ResetBoardDayAsync()
    {
        _resettingBoard = true;
        _resetBoardMsg  = null;
        await BoardSvc.ResetDayAsync(EventId, _resetDay);
        _blockHitScripts = await BoardSvc.GetScriptedBlockHitsAsync(EventId);
        _resetBoardMsg   = $"Day {_resetDay} reset — all groups returned to space 0.";
        _resettingBoard  = false;
        StateHasChanged();
        await Task.Delay(4000);
        _resetBoardMsg = null;
        StateHasChanged();
    }

    private async Task ResetMiniGameDayAsync()
    {
        _resettingMiniGame = true;
        _resetMiniGameMsg  = null;
        await MiniGameSvc.ResetDayAsync(EventId, _resetMiniGameDay);
        _miniGameScripts   = await MiniGameSvc.GetScriptsAsync(EventId);
        _resetMiniGameMsg  = $"Day {_resetMiniGameDay} mini-game reset.";
        _resettingMiniGame = false;
        StateHasChanged();
        await Task.Delay(4000);
        _resetMiniGameMsg = null;
        StateHasChanged();
    }

    private static string SpaceColor(string cat) => cat switch
    {
        "BoardStart"     => "#95A5A6",
        "BoardCoinBonus" => "#F39C12",
        "BoardPrestige"  => "#E74C3C",
        "BoardPenalty"   => "#C0392B",
        "MinuteToWinIt"  => "#9B59B6",
        _                => "#607D8B"
    };

    private static string SpaceIcon(string cat) => cat switch
    {
        "BoardStart"     => "🏁",
        "BoardCoinBonus" => "🪙",
        "BoardPrestige"  => "⭐",
        "BoardPenalty"   => "👹",
        "MinuteToWinIt"  => "🎮",
        _                => "❓"
    };

    private static string ThStyle() =>
        "padding:10px 14px;text-align:left;font-family:'Fredoka One',cursive;font-size:12px;letter-spacing:.5px;color:white";

    private static string TdStyle() =>
        "padding:10px 14px;border-bottom:2px solid #E8E0CC;vertical-align:middle;font-size:13px";
}
