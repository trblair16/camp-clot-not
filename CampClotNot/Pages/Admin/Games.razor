    private void SetFaceEmoji(int idx, ChangeEventArgs e) =>
        _editFaces[idx] = _editFaces[idx] with { Emoji = e.Value?.ToString() ?? "" };

    private void SetFaceLabel(int idx, ChangeEventArgs e) =>
        _editFaces[idx] = _editFaces[idx] with { Label = e.Value?.ToString() ?? "" };

    private void SetFaceCoins(int idx, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _editFaces[idx] = _editFaces[idx] with { CoinDelta = v };
    }

    private static BowserFace[] CreateDefaultEditFaces() =>
    [
        new("", "", "💀", -50, 0),
        new("", "", "👎", -30, 0),
        new("", "", "😤", -20, 0),
        new("", "", "😅", +10, 0),
        new("", "", "😏", +15, 0),
        new("", "", "😈", -5, 0),
    ];

    private void LoadDefaults()
    {
        _editFaces = BowserEventService.DefaultFaces.ToArray();
    }

    private void EditScript(BowserScript script)
    {
        _editingScript = script;
        _scriptName = script.Name;
        var faces = BowserEventService.ParseFaces(script.FacesJson);
        _editFaces = new BowserFace[6];
        for (var i = 0; i < 6; i++)
            _editFaces[i] = i < faces.Length ? faces[i] : new("", "", "", 0, 0);
    }

    private void CancelEdit()
    {
        _editingScript = null;
        _scriptName = "";
        _editFaces = CreateDefaultEditFaces();
    }

    private async Task SaveScriptAsync()
    {
        if (string.IsNullOrWhiteSpace(_scriptName)) return;

        var faces = _editFaces.Select(f => new BowserFace(
            string.IsNullOrWhiteSpace(f.Label) ? $"{(f.CoinDelta >= 0 ? "+" : "")}{f.CoinDelta} Coins" : f.Label,
            string.IsNullOrWhiteSpace(f.Description) ? $"Bowser: {(f.CoinDelta >= 0 ? "+" : "")}{f.CoinDelta} coins" : f.Description,
            string.IsNullOrWhiteSpace(f.Emoji) ? "🎲" : f.Emoji,
            f.CoinDelta,
            f.StarDelta
        )).ToArray();

        var facesJson = System.Text.Json.JsonSerializer.Serialize(faces);

        var script = _editingScript ?? new BowserScript { EventId = EventId };
        script.Name = _scriptName;
        script.FacesJson = facesJson;
        script.SortOrder = _editingScript?.SortOrder ?? (_bowserScripts?.Count ?? 0);

        await BowserSvc.UpsertScriptAsync(script);
        _bowserScripts = await BowserSvc.GetScriptsAsync(EventId);

        _bowserSaveMsg = $"'{_scriptName}' saved.";
        _editingScript = null;
        _scriptName = "";
        _editFaces = CreateDefaultEditFaces();
        StateHasChanged();

        await Task.Delay(2500);
        _bowserSaveMsg = null;
        StateHasChanged();
    }

    private async Task DeleteScriptAsync(Guid scriptId)
    {
        await BowserSvc.DeleteScriptAsync(scriptId);
        _bowserScripts = await BowserSvc.GetScriptsAsync(EventId);
    }

