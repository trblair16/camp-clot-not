@page "/admin/groups"
@attribute [Authorize(Roles = "Admin")]
@inject GroupService GroupSvc
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Manage Groups — Camp Clot Not</PageTitle>

<style>
    @@media (max-width: 699px) {
        .admin-grp-form        { display: none; }
        .admin-grp-table       { display: none; }
        .admin-grp-cards       { display: flex; flex-direction: column; gap: 10px; }
        .admin-grp-add-mobile  { display: block; margin-bottom: 12px; }
    }
    @@media (min-width: 700px) {
        .admin-grp-cards      { display: none; }
        .admin-grp-add-mobile { display: none; }
    }
</style>

<div style="padding: 0 16px 100px">
    <h2 style="font-family:'Fredoka One',cursive;font-size:22px;margin:0 0 20px"><img src="/img/icons/people.svg" style="width:20px;height:20px;vertical-align:middle;margin-right:6px;opacity:.8" alt="" />Groups</h2>

    <div style="display:flex;gap:20px;align-items:flex-start;flex-wrap:wrap">

        @* ── Form panel (desktop) / mobile overlay ── *@
        <div style="@(_mobileFormOpen ? "position:fixed;inset:0;background:rgba(26,26,26,.65);z-index:100;overflow-y:auto;display:flex;align-items:flex-start;justify-content:center;padding:16px;animation:fadeIn .15s ease" : "display:contents")"
             @onclick="CloseFormOverlay">
        <div class="admin-grp-form" style="background:var(--panel-bg);border:3px solid var(--black);border-radius:10px;box-shadow:@(_mobileFormOpen ? "8px 8px 0 var(--black)" : "4px 4px 0 var(--black)");padding:20px;flex:0 0 320px;min-width:260px;@(_mobileFormOpen ? "display:block !important;max-width:480px;width:100%;margin:auto;animation:popIn .2s ease" : "")"
             @onclick:stopPropagation>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
                <h3 style="font-family:'Fredoka One',cursive;font-size:16px;margin:0">@(_editing is null ? "Add Group" : "Edit Group")</h3>
                @if (_mobileFormOpen)
                {
                    <button @onclick="CloseFormOverlay" style="background:none;border:none;font-size:22px;cursor:pointer;line-height:1;color:var(--text-light);padding:0">✕</button>
                }
            </div>

            <div style="margin-bottom:14px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Display Name</div>
                <input type="text" @bind="_form.Name" placeholder="e.g. Mini Marios"
                       style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
            </div>

            <div style="margin-bottom:14px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Short Name</div>
                <input type="text" @bind="_form.ShortName" placeholder="e.g. MM"
                       style="width:100%;padding:9px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:14px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
            </div>

            <div style="margin-bottom:14px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Color</div>
                <div style="display:flex;align-items:center;gap:12px">
                    <div style="@($"width:48px;height:48px;border-radius:8px;border:3px solid var(--black);background:{_form.Color};box-shadow:2px 2px 0 var(--black);flex-shrink:0")"></div>
                    <div style="flex:1;display:flex;flex-direction:column;gap:6px">
                        <input type="color" value="@_form.Color" @oninput="ColorPickerChanged"
                               style="width:100%;height:34px;border:3px solid var(--black);border-radius:6px;padding:2px 4px;cursor:pointer;background:white;box-shadow:2px 2px 0 var(--black)" />
                        <input type="text" @bind="_form.Color" placeholder="#4CAF50"
                               style="width:100%;padding:7px 10px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:13px;font-family:monospace;font-weight:700;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
                    </div>
                </div>
            </div>

            <div style="margin-bottom:16px">
                <div style="font-size:10px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);margin-bottom:5px">Team Logo</div>
                <div style="display:flex;align-items:center;gap:12px">
                    <div style="@($"width:48px;height:48px;border-radius:50%;border:3px solid {_form.Color};background:{_form.Color}22;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden")">
                        @if (_form.LogoDataUrl is not null)
                        {
                            <img src="@_form.LogoDataUrl" style="width:100%;height:100%;object-fit:contain" />
                        }
                        else
                        {
                            <span style="font-size:20px">🖼️</span>
                        }
                    </div>
                    <div style="flex:1;display:flex;flex-direction:column;gap:6px">
                        <InputFile OnChange="OnLogoSelected" accept="image/*" style="font-size:12px;width:100%" />
                        <p style="font-size:11px;color:var(--text-light);margin:0">PNG or SVG · max 500 KB</p>
                        @if (_form.LogoDataUrl is not null)
                        {
                            <button class="ccn-btn" style="font-size:11px;padding:3px 10px;background:#D12B2B;color:white" @onclick="RemoveLogo">Remove</button>
                        }
                    </div>
                </div>
            </div>

            <div style="display:flex;gap:8px">
                <button class="ccn-btn" @onclick="SaveAsync">@(_editing is null ? "Add Group" : "Save Changes")</button>
                @if (_editing is not null)
                {
                    <button class="ccn-btn" style="background:transparent" @onclick="CancelEdit">Cancel</button>
                }
            </div>
        </div>
        </div>

        @* ── Table ── *@
        <div style="flex:1;min-width:260px">
            <button class="ccn-btn admin-grp-add-mobile" @onclick="() => _mobileFormOpen = true">+ Add Group</button>

            @if (!_groups.Any())
            {
                <p style="color:var(--text-light);font-family:'Fredoka One',cursive">No groups yet.</p>
            }
            else
            {
                <div class="admin-grp-cards">
                    @foreach (var g in _groups)
                    {
                        <div style="background:var(--panel-bg);border:3px solid var(--black);border-radius:10px;box-shadow:3px 3px 0 var(--black);padding:12px 14px;display:flex;justify-content:space-between;align-items:center;gap:8px">
                            <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0">
                                <div style="@($"width:28px;height:28px;border-radius:6px;border:2px solid var(--black);background:{g.Color};flex-shrink:0")"></div>
                                <div style="min-width:0">
                                    <div style="font-family:'Fredoka One',cursive;font-size:15px;color:var(--black)">@g.Name <span style="font-size:12px;color:var(--text-light)">(@g.ShortName)</span></div>
                                    @if (g.TokenAssetPath is not null)
                                    {
                                        <img src="@g.TokenAssetPath" style="width:22px;height:22px;object-fit:contain;margin-top:2px" />
                                    }
                                </div>
                            </div>
                            <div style="display:flex;flex-direction:column;gap:4px;flex-shrink:0">
                                <button class="ccn-btn" style="font-size:11px;padding:4px 12px" @onclick="() => { StartEdit(g); _mobileFormOpen = true; }">Edit</button>
                                <button class="ccn-btn" style="font-size:11px;padding:4px 12px;background:#D12B2B;color:white" @onclick="() => DeleteAsync(g)">Del</button>
                            </div>
                        </div>
                    }
                </div>

                <div class="admin-grp-table" style="border:3px solid var(--black);border-radius:10px;box-shadow:4px 4px 0 var(--black);overflow:hidden">
                    <table style="width:100%;border-collapse:collapse">
                        <thead>
                            <tr style="background:var(--black)">
                                <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Name</th>
                                <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Short</th>
                                <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Color</th>
                                <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Logo</th>
                                <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var g in _groups)
                            {
                                <tr style="border-bottom:2px solid #E8E0CC">
                                    <td style="padding:10px 14px;font-size:13px;font-weight:700">@g.Name</td>
                                    <td style="padding:10px 14px;font-size:13px">@g.ShortName</td>
                                    <td style="padding:10px 14px">
                                        <div style="display:flex;align-items:center;gap:8px">
                                            <div style="@($"width:22px;height:22px;border-radius:5px;border:2px solid var(--black);background:{g.Color};flex-shrink:0")"></div>
                                            <span style="font-size:11px;color:var(--text-mid);font-family:monospace">@g.Color</span>
                                        </div>
                                    </td>
                                    <td style="padding:10px 14px">
                                        @if (g.TokenAssetPath is not null)
                                        {
                                            <img src="@g.TokenAssetPath" style="width:28px;height:28px;object-fit:contain" />
                                        }
                                        else
                                        {
                                            <span style="font-size:12px;color:var(--text-light)">—</span>
                                        }
                                    </td>
                                    <td style="padding:8px 10px">
                                        <div style="display:flex;gap:4px">
                                            <button class="ccn-btn" style="font-size:11px;padding:4px 10px" @onclick="() => StartEdit(g)">Edit</button>
                                            <button class="ccn-btn" style="font-size:11px;padding:4px 10px;background:#D12B2B;color:white" @onclick="() => DeleteAsync(g)">Del</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</div>

@code {
    private List<Group> _groups = new();
    private GroupForm _form = new();
    private Group? _editing;
    private bool _mobileFormOpen;

    protected override async Task OnInitializedAsync() =>
        _groups = await GroupSvc.GetAllAsync();

    private void StartEdit(Group g)
    {
        _editing = g;
        _form = new GroupForm
        {
            Name        = g.Name,
            ShortName   = g.ShortName,
            Color       = g.Color,
            LogoDataUrl = g.TokenAssetPath
        };
    }

    private void CancelEdit() { _editing = null; _form = new(); _mobileFormOpen = false; }

    private void CloseFormOverlay() => CancelEdit();

    private void ColorPickerChanged(ChangeEventArgs e) =>
        _form.Color = e.Value?.ToString() ?? _form.Color;

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 500 * 1024)
        {
            Snackbar.Add("Image exceeds 500 KB — please use a smaller file.", Severity.Warning);
            return;
        }
        using var stream = file.OpenReadStream(maxAllowedSize: 500 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        _form.LogoDataUrl = $"data:{file.ContentType};base64,{base64}";
    }

    private void RemoveLogo() => _form.LogoDataUrl = null;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) return;

        var defaultEventId = _groups.FirstOrDefault()?.EventId ?? new Guid("00000009-0009-0009-0009-000000000001");

        if (_editing is null)
        {
            await GroupSvc.CreateAsync(_form.Name, _form.ShortName, _form.Color, defaultEventId, _form.LogoDataUrl);
            Snackbar.Add("Group added.", Severity.Success);
        }
        else
        {
            await GroupSvc.UpdateAsync(_editing.GroupId, _form.Name, _form.ShortName, _form.Color,
                _form.LogoDataUrl, _editing.CabinDisplayName);
            Snackbar.Add("Group updated.", Severity.Success);
            _editing = null;
        }
        _form = new();
        _groups = await GroupSvc.GetAllAsync();
    }

    private async Task DeleteAsync(Group g)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Group", $"Delete {g.Name}? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (result != true) return;
        await GroupSvc.DeleteAsync(g.GroupId);
        _groups = await GroupSvc.GetAllAsync();
        Snackbar.Add("Group deleted.", Severity.Info);
    }

    private class GroupForm
    {
        public string Name { get; set; } = "";
        public string ShortName { get; set; } = "";
        public string Color { get; set; } = "#4CAF50";
        public string? LogoDataUrl { get; set; }
    }
}
