@page "/bowser"
@attribute [Authorize(Roles = "Admin")]
@inject BowserEventService BowserSvc
@inject GroupService GroupSvc
@inject AuthenticationStateProvider Auth

<PageTitle>Bowser Event — Camp Clot Not</PageTitle>

<div style="padding: 0 16px 100px">
    <h2 style="font-family:'Fredoka One',cursive;font-size:22px;margin:0 0 6px">
        <img src="/img/bowser-space.png" style="width:28px;height:28px;vertical-align:middle;margin-right:6px;border-radius:50%;object-fit:cover" alt="" />Bowser Event
    </h2>
    <p style="font-size:13px;color:var(--text-light);margin:0 0 20px">Each group rolls the Bowser die. Results are applied automatically.</p>

    <div style="display:flex;gap:12px;align-items:center;margin-bottom:20px;flex-wrap:wrap">
        <a href="/bowser/display" target="_blank" class="ccn-btn" style="font-size:13px;padding:8px 16px;text-decoration:none;display:inline-block">
            📺 Open Projector Display
        </a>

        <select value="@(_selectedScriptId?.ToString() ?? "")"
                @onchange="OnScriptChanged"
                style="padding:8px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;cursor:pointer">
            <option value="">Default Die</option>
            @foreach (var s in _scripts)
            {
                <option value="@s.BowserScriptId">@s.Name</option>
            }
        </select>
    </div>

    @if (_activeFaces.Length > 0)
    {
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px">
            @foreach (var f in _activeFaces)
            {
                <span style="font-size:12px;padding:4px 10px;border:2px solid var(--black);border-radius:6px;background:var(--panel-bg);box-shadow:1px 1px 0 var(--black)">
                    @f.Emoji @f.Label
                </span>
            }
        </div>
    }

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:12px">
            @foreach (var g in _groups)
            {
                var hasResult = _results.ContainsKey(g.GroupId);
                <div style="border:3px solid var(--black);border-radius:10px;padding:16px;box-shadow:3px 3px 0 var(--black);background:var(--panel-bg);display:flex;justify-content:space-between;align-items:center;gap:12px">
                    <div>
                        <div style="font-family:'Fredoka One',cursive;font-size:18px;color:@g.Color">@g.Name</div>
                        @if (hasResult)
                        {
                            var r = _results[g.GroupId];
                            <div style="font-size:14px;margin-top:4px">
                                <span style="font-size:18px">@r.face.Emoji</span>
                                <span style="font-family:'Fredoka One',cursive;color:var(--black)">@r.face.Label</span>
                                <span style="font-size:12px;color:var(--text-light);margin-left:6px">@r.face.Description</span>
                            </div>
                        }
                    </div>
                    @if (!hasResult)
                    {
                        <button class="ccn-btn" style="font-size:14px;padding:10px 20px;background:#D12B2B;color:white"
                                disabled="@_rolling" @onclick="() => RollAsync(g)">
                            🎲 Roll
                        </button>
                    }
                    else
                    {
                        <div style="display:flex;align-items:center;gap:8px">
                            <span style="font-family:'Fredoka One',cursive;font-size:12px;color:var(--text-light)">✓ Done</span>
                            <button class="ccn-btn" style="font-size:10px;padding:3px 8px;background:#E67E22;color:white"
                                    @onclick="() => ResetGroup(g.GroupId)">Reset</button>
                        </div>
                    }
                </div>
            }
        </div>

        @if (_results.Count > 0)
        {
            <div style="margin-top:20px">
                <button class="ccn-btn" style="background:transparent;border-color:var(--black);color:var(--black)"
                        @onclick="ResetDisplay">Reset Display</button>
            </div>
        }
    }
</div>

@code {
    private List<Group> _groups = new();
    private List<BowserScript> _scripts = new();
    private Guid? _selectedScriptId;
    private BowserFace[] _activeFaces = BowserEventService.DefaultFaces;
    private Dictionary<Guid, (int faceIndex, BowserFace face)> _results = new();
    private bool _loading = true;
    private bool _rolling;
    private string _userName = "Admin";

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        _userName = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Admin";
        _groups = await GroupSvc.GetAllAsync();
        _scripts = await BowserSvc.GetScriptsAsync(SeedService.Id.EventCcn2026);
        _loading = false;
    }

    private void OnScriptChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        if (Guid.TryParse(val, out var id))
        {
            _selectedScriptId = id;
            var script = _scripts.FirstOrDefault(s => s.BowserScriptId == id);
            _activeFaces = BowserEventService.ParseFaces(script?.FacesJson);
        }
        else
        {
            _selectedScriptId = null;
            _activeFaces = BowserEventService.DefaultFaces;
        }
    }

    private async Task RollAsync(Group group)
    {
        _rolling = true;
        StateHasChanged();

        await BowserSvc.BroadcastRollStart(group.GroupId, group.Name, group.Color, _activeFaces);
        await Task.Delay(500);

        var (faceIndex, face) = await BowserSvc.RollAsync(group.GroupId, SeedService.Id.EventCcn2026, _userName, _selectedScriptId);
        _results[group.GroupId] = (faceIndex, face);

        await Task.Delay(3000);

        await BowserSvc.BroadcastResult(group.GroupId, faceIndex, face.Label, face.Description);
        _rolling = false;
    }

    private void ResetGroup(Guid groupId)
    {
        _results.Remove(groupId);
    }

    private async Task ResetDisplay()
    {
        await BowserSvc.BroadcastReset();
    }
}
