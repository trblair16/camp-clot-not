@page "/transactions"
@attribute [Authorize]
@inject TransactionService TxSvc
@inject GroupService GroupSvc
@inject IDialogService DialogService

<PageTitle>Transactions — Camp Clot Not</PageTitle>

<div style="padding: 0 16px 100px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
        <h2 style="font-family:'Fredoka One',cursive;font-size:22px;margin:0"><img src="/img/icons/transactions.svg?v=3" style="width:20px;height:20px;vertical-align:middle;margin-right:6px;opacity:.8" alt="" />Transaction Log</h2>
        <button class="ccn-btn" style="font-size:12px;padding:6px 14px" @onclick="LoadAsync">↺ Refresh</button>
    </div>

    <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;align-items:center">
        <input type="text" @bind="_search" @bind:event="oninput" placeholder="Search..."
               style="flex:1;min-width:150px;padding:8px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;box-sizing:border-box" />
        <select class="tx-filter" value="@_filterGroup" @onchange="e => _filterGroup = e.Value?.ToString() ?? string.Empty"
                style="padding:8px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;cursor:pointer">
            <option value="">All Groups</option>
            @foreach (var g in _groups)
            {
                <option value="@g.Name">@g.Name</option>
            }
        </select>
        <select class="tx-filter" value="@_filterType" @onchange="e => _filterType = e.Value?.ToString() ?? string.Empty"
                style="padding:8px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;cursor:pointer">
            <option value="">All Types</option>
            <option value="Primary">Coins</option>
            <option value="Prestige">Stars</option>
        </select>
        <select class="tx-filter" value="@_filterStatus" @onchange="e => _filterStatus = e.Value?.ToString() ?? string.Empty"
                style="padding:8px 12px;background:var(--bg-base);border:3px solid var(--black);border-radius:7px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text-dark);box-shadow:2px 2px 0 var(--black);outline:none;cursor:pointer">
            <option value="">All Status</option>
            <option value="active">Active</option>
            <option value="voided">Voided</option>
        </select>
    </div>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (!FilteredTransactions.Any())
    {
        <p style="color:var(--text-light);font-family:'Fredoka One',cursive">No transactions yet.</p>
    }
    else
    {
        @* ── Mobile cards (hidden ≥700px) ── *@
        <div class="tx-mobile-cards">
            @foreach (var tx in FilteredTransactions)
            {
                var voided = tx.VoidedAt.HasValue;
                var isCoins = tx.CurrencyType?.SystemName == nameof(Currency.Primary);
                var amtColor = voided ? "var(--text-light)" : tx.Amount < 0 ? "#D12B2B" : "#1A7A3E";
                <div style="border:3px solid var(--black);border-radius:10px;box-shadow:3px 3px 0 var(--black);background:var(--panel-bg);padding:12px 14px;margin-bottom:10px;@(voided ? "opacity:.5" : "")">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
                        <span style="font-family:'Fredoka One',cursive;font-size:14px;color:@(tx.Group?.Color ?? "var(--black)")">@tx.Group?.Name</span>
                        <span style="font-weight:800;font-size:15px;color:@amtColor;@(voided ? "text-decoration:line-through" : "");display:inline-flex;align-items:center;gap:3px">@(tx.Amount > 0 ? "+" : "")@tx.Amount <img src="@(isCoins ? "/img/ccn-coin.png" : "/img/ccn-star.png")" style="height:16px;width:auto" alt="" /></span>
                    </div>
                    <div style="font-size:11px;color:var(--text-light);margin-bottom:4px">
                        @tx.CreatedAt.ToString("MM/dd h:mm tt") · @tx.LoggedBy
                    </div>
                    @if (!string.IsNullOrEmpty(tx.Note))
                    {
                        <div style="font-size:12px;color:var(--text-mid);margin-bottom:6px">@tx.Note</div>
                    }
                    <div style="display:flex;justify-content:space-between;align-items:center">
                        @if (voided)
                        {
                            <span style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:white;background:#D12B2B;padding:2px 8px;border-radius:4px;border:2px solid var(--black)">VOIDED</span>
                        }
                        else
                        {
                            <span style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:white;background:#27AE60;padding:2px 8px;border-radius:4px;border:2px solid var(--black)">Active</span>
                        }
                        <AuthorizeView Roles="Admin">
                            @if (!voided)
                            {
                                <button class="ccn-btn" style="font-size:11px;padding:4px 10px;background:#D12B2B;color:white" @onclick="() => VoidAsync(tx)">Void</button>
                            }
                            else
                            {
                                <button class="ccn-btn" style="font-size:11px;padding:4px 10px;background:#E67E22;color:white" @onclick="() => ReinstateAsync(tx)">Reinstate</button>
                            }
                        </AuthorizeView>
                    </div>
                </div>
            }
        </div>

        @* ── Desktop table (hidden <700px) ── *@
        <div class="tx-desktop-table" style="border:3px solid var(--black);border-radius:10px;box-shadow:4px 4px 0 var(--black);overflow:hidden">
            <table style="width:100%;border-collapse:collapse">
                <thead>
                    <tr style="background:var(--black)">
                        <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left;white-space:nowrap">Time</th>
                        <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Group</th>
                        <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Type</th>
                        <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:right">Amount</th>
                        <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Logged By</th>
                        <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Note</th>
                        <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left">Status</th>
                        <AuthorizeView Roles="Admin">
                            <th style="padding:10px 14px;color:white;font-family:'Fredoka One',cursive;font-size:12px;text-align:left"></th>
                        </AuthorizeView>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in FilteredTransactions)
                    {
                        var voided   = tx.VoidedAt.HasValue;
                        var isCoins  = tx.CurrencyType?.SystemName == nameof(Currency.Primary);
                        var amtColor = voided ? "var(--text-light)" : tx.Amount < 0 ? "#D12B2B" : "#1A7A3E";
                        <tr style="border-bottom:2px solid #E8E0CC;@(voided ? "opacity:.5" : "")">
                            <td style="padding:10px 14px;font-size:12px;color:var(--text-mid);white-space:nowrap">
                                @tx.CreatedAt.ToString("MM/dd h:mm tt")
                            </td>
                            <td style="padding:10px 14px;font-size:13px;font-weight:700">@tx.Group?.Name</td>
                            <td style="padding:10px 14px;font-size:13px"><img src="@(isCoins ? "/img/ccn-coin.png" : "/img/ccn-star.png")" style="height:14px;width:auto;vertical-align:middle;margin-right:3px" alt="" />@(isCoins ? "Coins" : "Stars")</td>
                            <td style="padding:10px 14px;font-size:13px;font-weight:800;text-align:right;color:@amtColor;@(voided ? "text-decoration:line-through" : "")">
                                @(tx.Amount > 0 ? "+" : "")@tx.Amount
                            </td>
                            <td style="padding:10px 14px;font-size:12px;color:var(--text-mid)">@tx.LoggedBy</td>
                            <td style="padding:10px 14px;font-size:12px;color:var(--text-mid);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                @(string.IsNullOrEmpty(tx.Note) ? "—" : tx.Note)
                            </td>
                            <td style="padding:8px 14px">
                                @if (voided)
                                {
                                    <span style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;
                                                 color:white;background:#D12B2B;padding:2px 8px;border-radius:4px;
                                                 border:2px solid var(--black);display:inline-block">VOIDED</span>
                                }
                                else
                                {
                                    <span style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;
                                                 color:white;background:#27AE60;padding:2px 8px;border-radius:4px;
                                                 border:2px solid var(--black);display:inline-block">Active</span>
                                }
                            </td>
                            <AuthorizeView Roles="Admin">
                                <td style="padding:8px 10px">
                                    @if (!voided)
                                    {
                                        <button class="ccn-btn" style="font-size:11px;padding:4px 10px;background:#D12B2B;color:white"
                                                @onclick="() => VoidAsync(tx)">Void</button>
                                    }
                                    else
                                    {
                                        <button class="ccn-btn" style="font-size:11px;padding:4px 10px;background:#E67E22;color:white"
                                                @onclick="() => ReinstateAsync(tx)">Reinstate</button>
                                    }
                                </td>
                            </AuthorizeView>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    @@media (max-width: 699px) {
        .tx-desktop-table { display: none; }
        .tx-filter { display: none; }
    }
    @@media (min-width: 700px) {
        .tx-mobile-cards { display: none; }
    }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    private List<Transaction> _transactions = new();
    private List<Group> _groups = new();
    private bool _loading = true;
    private string _search = "";
    private string _filterGroup = "";
    private string _filterType = "";
    private string _filterStatus = "";

    private IEnumerable<Transaction> FilteredTransactions => _transactions.Where(tx =>
    {
        if (!string.IsNullOrEmpty(_filterGroup) && tx.Group?.Name != _filterGroup) return false;
        if (!string.IsNullOrEmpty(_filterType) && tx.CurrencyType?.SystemName != _filterType) return false;
        if (_filterStatus == "active" && tx.VoidedAt.HasValue) return false;
        if (_filterStatus == "voided" && !tx.VoidedAt.HasValue) return false;
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            return (tx.Group?.Name?.Contains(s, StringComparison.OrdinalIgnoreCase) == true)
                || (tx.LoggedBy?.Contains(s, StringComparison.OrdinalIgnoreCase) == true)
                || (tx.Note?.Contains(s, StringComparison.OrdinalIgnoreCase) == true)
                || tx.Amount.ToString().Contains(s);
        }
        return true;
    });

    protected override async Task OnInitializedAsync()
    {
        _groups = await GroupSvc.GetAllAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _transactions = await TxSvc.GetAllAsync();
        _loading = false;
    }

    private async Task VoidAsync(Transaction tx)
    {
        var currencyLabel = tx.CurrencyType?.SystemName == nameof(Currency.Primary) ? "coin" : "star";
        var result = await DialogService.ShowMessageBox(
            "Void Transaction",
            $"Void this {currencyLabel} transaction of {tx.Amount:+0;-0} for {tx.Group?.Name}?",
            yesText: "Void", cancelText: "Cancel");
        if (result != true) return;

        var state = await AuthState;
        var name = state.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "unknown";
        await TxSvc.VoidAsync(tx.TxId, name);
        _transactions = await TxSvc.GetAllAsync();
    }

    private async Task ReinstateAsync(Transaction tx)
    {
        var currencyLabel = tx.CurrencyType?.SystemName == nameof(Currency.Primary) ? "coin" : "star";
        var result = await DialogService.ShowMessageBox(
            "Reinstate Transaction",
            $"Reinstate this {currencyLabel} transaction of {tx.Amount:+0;-0} for {tx.Group?.Name}? It will count toward their score again.",
            yesText: "Reinstate", cancelText: "Cancel");
        if (result != true) return;

        await TxSvc.ReinstateAsync(tx.TxId);
        _transactions = await TxSvc.GetAllAsync();
    }
}
